---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'あなたの街の"もらえるお金"、30秒で全部わかる。個人向け補助金・助成金の横断検索＆自治体比較サイト。' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | ホジョタウン</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700&display=swap" rel="stylesheet" />
  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6323187276389571" crossorigin="anonymous"></script>
  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-M90YY0H2EN"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-M90YY0H2EN');
  </script>
  <!-- OGP -->
  <meta property="og:title" content={`${title} | ホジョタウン`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ホジョタウン" />
  <meta property="og:image" content="https://hojotown.jp/ogp.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://hojotown.jp/ogp.png" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">ホジョ<span>タウン</span></a>
      <nav>
        <ul class="site-nav">
          <li><a href="/shindan/">診断</a></li>
          <li><a href="/compare/">比較</a></li>
        </ul>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="メニュー">
        <span></span><span></span><span></span>
      </button>
      <div class="mobile-nav" id="mobile-nav">
        <a href="/shindan/">診断</a>
        <a href="/compare/">比較</a>
        <a href="/about/">運営者情報</a>
        <a href="/contact/">お問い合わせ</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <ul class="footer-links">
        <li><a href="/about/">運営者情報</a></li>
        <li><a href="/privacy/">プライバシーポリシー</a></li>
        <li><a href="/terms/">利用規約・免責事項</a></li>
        <li><a href="/contact/">お問い合わせ</a></li>
      </ul>
      <p class="footer-copy">&copy; 2026 ホジョタウン. 掲載情報は各自治体の公式HPをご確認ください。</p>
    </div>
  </footer>
  <script>
    // ハンバーガーメニュー
    document.getElementById('hamburger')?.addEventListener('click', function() {
      this.classList.toggle('active');
      document.getElementById('mobile-nav')?.classList.toggle('open');
    });

    // 位置情報自動判定（全ページ共通）
    (function() {
      if (!navigator.geolocation || localStorage.getItem('hojotown_city')) return;
      navigator.geolocation.getCurrentPosition(function(pos) {
        const cities = [
          {name:'川越市',slug:'kawagoe',pref:'saitama',lat:35.925,lng:139.486},
          {name:'さいたま市',slug:'saitama',pref:'saitama',lat:35.861,lng:139.645},
          {name:'所沢市',slug:'tokorozawa',pref:'saitama',lat:35.799,lng:139.469},
          {name:'川口市',slug:'kawaguchi',pref:'saitama',lat:35.808,lng:139.724},
          {name:'横浜市',slug:'yokohama',pref:'kanagawa',lat:35.444,lng:139.638},
          {name:'川崎市',slug:'kawasaki',pref:'kanagawa',lat:35.531,lng:139.703},
          {name:'千葉市',slug:'chiba',pref:'chiba',lat:35.607,lng:140.106},
          {name:'名古屋市',slug:'nagoya',pref:'aichi',lat:35.181,lng:136.906},
          {name:'札幌市',slug:'sapporo',pref:'hokkaido',lat:43.062,lng:141.354},
          {name:'仙台市',slug:'sendai',pref:'miyagi',lat:38.268,lng:140.872},
          {name:'大阪市',slug:'osaka',pref:'osaka',lat:34.694,lng:135.502},
          {name:'神戸市',slug:'kobe',pref:'hyogo',lat:34.691,lng:135.183},
          {name:'京都市',slug:'kyoto',pref:'kyoto',lat:35.012,lng:135.768},
          {name:'広島市',slug:'hiroshima',pref:'hiroshima',lat:34.396,lng:132.460},
          {name:'福岡市',slug:'fukuoka',pref:'fukuoka',lat:33.590,lng:130.402},
        ];
        var lat=pos.coords.latitude, lng=pos.coords.longitude;
        var min=Infinity, best=null;
        for(var i=0;i<cities.length;i++){
          var d=Math.sqrt(Math.pow(lat-cities[i].lat,2)+Math.pow(lng-cities[i].lng,2));
          if(d<min){min=d;best=cities[i];}
        }
        if(best && min < 0.5) {
          localStorage.setItem('hojotown_city', JSON.stringify(best));
          // ログ保存
          var log = JSON.parse(localStorage.getItem('hojotown_geo_log') || '[]');
          log.push({ts:new Date().toISOString(),lat:lat,lng:lng,matched:best.name});
          localStorage.setItem('hojotown_geo_log', JSON.stringify(log));
        }
      }, function(){}, {timeout:8000});
    })();
  </script>
</body>
</html>
