---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = 'あなたの街の"もらえるお金"、30秒で全部わかる。個人向け補助金・助成金の横断検索＆自治体比較サイト。', noindex = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | ホジョタウン</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow, noarchive" />}
  <script>
    window.__HOJOTOWN_AB__ = window.__HOJOTOWN_AB__ || {};
    (function() {
      const tests = {
        article_cta_copy: ['a', 'b'],
        shindan_result_cta_position: ['a', 'b'],
      };

      Object.entries(tests).forEach(([testName, variants]) => {
        const storageKey = `hojotown_ab_${testName}`;
        let variant = '';
        try {
          variant = localStorage.getItem(storageKey) || '';
          if (!variants.includes(variant)) {
            variant = variants[Math.floor(Math.random() * variants.length)];
            localStorage.setItem(storageKey, variant);
          }
        } catch (_) {
          variant = variants[0];
        }
        window.__HOJOTOWN_AB__[testName] = variant;
        document.documentElement.setAttribute(`data-ab-${testName.replaceAll('_', '-')}`, variant);
      });
    })();
  </script>
  <style>
    html[data-ab-shindan-result-cta-position="a"] [data-ab-test="shindan_result_cta_position"][data-ab-show="b"],
    html[data-ab-shindan-result-cta-position="b"] [data-ab-test="shindan_result_cta_position"][data-ab-show="a"] {
      display: none !important;
    }
  </style>
  <link rel="canonical" href={`https://hojotown.jp${Astro.url.pathname}`} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700&display=swap" rel="stylesheet" />
  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6821699059443804" crossorigin="anonymous"></script>
  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-1HG75RFJ2K"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    // 内部トラフィック判定（自分のIPを除外）
    fetch('https://api.ipify.org?format=json').then(r=>r.json()).then(d=>{
      if(d.ip==='133.203.175.0'){
        gtag('config','G-1HG75RFJ2K',{traffic_type:'internal'});
      }else{
        gtag('config','G-1HG75RFJ2K');
      }
    }).catch(()=>gtag('config','G-1HG75RFJ2K'));
  </script>
  <!-- OGP -->
  <meta property="og:title" content={`${title} | ホジョタウン`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ホジョタウン" />
  <meta property="og:image" content="https://hojotown.jp/ogp.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://hojotown.jp/ogp.png" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">ホジョ<span>タウン</span></a>
      <nav>
        <ul class="site-nav">
          <li><a href="/shindan/">診断</a></li>
          <li><a href="/compare/">比較</a></li>
          <li><a href="/life/">ライフイベント</a></li>
        </ul>
      </nav>
      <button class="hamburger" id="hamburger" aria-label="メニュー">
        <span></span><span></span><span></span>
      </button>
      <div class="mobile-nav" id="mobile-nav">
        <a href="/shindan/">診断</a>
        <a href="/compare/">比較</a>
        <a href="/life/">ライフイベント</a>
        <a href="/about/">運営者情報</a>
        <a href="/contact/">お問い合わせ</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <ul class="footer-links">
        <li><a href="/about/">運営者情報</a></li>
        <li><a href="/privacy/">プライバシーポリシー</a></li>
        <li><a href="/terms/">利用規約・免責事項</a></li>
        <li><a href="/contact/">お問い合わせ</a></li>
      </ul>
      <p class="footer-copy">&copy; 2026 ホジョタウン. 掲載情報は各自治体の公式HPをご確認ください。</p>
    </div>
  </footer>
  <script>
    const GA_MEASUREMENT_ID = 'G-1HG75RFJ2K';

    function sendAffiliateClick(anchor) {
      const href = anchor.href || '';
      const abScope = anchor.closest?.('[data-ab-test]');
      const abTest = abScope?.dataset.abTest || '';
      const abVariant = abScope?.dataset.abVariant || abScope?.dataset.abShow || (abTest ? window.__HOJOTOWN_AB__?.[abTest] : '');
      let linkDomain = '';
      try {
        linkDomain = new URL(href).hostname;
      } catch (_) {
        linkDomain = '';
      }

      const isAffiliateLink = anchor.matches('[data-ad-id]') || linkDomain === 'px.a8.net';
      if (!isAffiliateLink || anchor.dataset.affiliateTracked === '1') return;
      anchor.dataset.affiliateTracked = '1';

      const payload = {
        ad_id: anchor.dataset.adId || 'unknown',
        source: anchor.dataset.source || anchor.dataset.lifeEvent || 'affiliate_link',
        position: Number(anchor.dataset.position || 0),
        link_url: href,
        link_domain: linkDomain,
        page_path: window.location.pathname,
        ab_test: abTest,
        ab_variant: abVariant,
      };

      if (typeof window.gtag === 'function') {
        window.gtag('event', 'affiliate_click', {
          ...payload,
          transport_type: 'beacon',
          send_to: GA_MEASUREMENT_ID,
        });
      }

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'hojotown_affiliate_click',
        ...payload,
      });
    }

    function applyArticleAdCopyTest() {
      const variant = window.__HOJOTOWN_AB__?.article_cta_copy || 'a';
      document.querySelectorAll('[data-ab-test="article_cta_copy"] .article-ad-card').forEach((card) => {
        card.dataset.abVariant = variant;
        if (variant !== 'b') return;
        const title = card.dataset.abTitleB;
        const desc = card.dataset.abDescB;
        const cta = card.dataset.abCtaB;
        if (title) card.querySelector('.article-ad-title').textContent = title;
        if (desc) card.querySelector('.article-ad-desc').textContent = desc;
        if (cta) card.querySelector('.article-ad-cta').textContent = cta;
      });
    }

    function sendAbAssignments() {
      if (typeof window.gtag !== 'function') return;
      Object.entries(window.__HOJOTOWN_AB__ || {}).forEach(([testName, variant]) => {
        window.gtag('event', 'ab_test_assigned', {
          ab_test: testName,
          ab_variant: variant,
          page_path: window.location.pathname,
          transport_type: 'beacon',
          send_to: GA_MEASUREMENT_ID,
        });
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      applyArticleAdCopyTest();
      sendAbAssignments();
    });

    document.addEventListener('click', function(event) {
      const anchor = event.target?.closest?.('a[href]');
      if (anchor) sendAffiliateClick(anchor);
    }, true);

    // ハンバーガーメニュー
    document.getElementById('hamburger')?.addEventListener('click', function() {
      this.classList.toggle('active');
      document.getElementById('mobile-nav')?.classList.toggle('open');
    });

    // 位置情報判定はindex.astroに一本化（BaseLayoutでは判定済みチェックのみ）
  </script>
</body>
</html>
