---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'あなたの街の"もらえるお金"、30秒で全部わかる。個人向け補助金・助成金の横断検索＆自治体比較サイト。' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | ホジョタウン</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700&display=swap" rel="stylesheet" />
  <!-- OGP -->
  <meta property="og:title" content={`${title} | ホジョタウン`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ホジョタウン" />
  <meta name="twitter:card" content="summary_large_image" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">ホジョ<span>タウン</span></a>
      <nav>
        <ul class="site-nav">
          <li><a href="/shindan/">診断</a></li>
          <li><a href="/ranking/">ランキング</a></li>
          <li><a href="/compare/">比較</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <ul class="footer-links">
        <li><a href="/about/">運営者情報</a></li>
        <li><a href="/privacy/">プライバシーポリシー</a></li>
        <li><a href="/terms/">利用規約・免責事項</a></li>
        <li><a href="/contact/">お問い合わせ</a></li>
      </ul>
      <p class="footer-copy">&copy; 2026 ホジョタウン. 掲載情報は各自治体の公式HPをご確認ください。</p>
    </div>
  </footer>
</body>
</html>
