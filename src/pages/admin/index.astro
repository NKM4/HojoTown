---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="管理ページ">
  <section style="padding: 32px 0; min-height: 80vh;">
    <div class="container" style="max-width: 900px;">
      <h1 style="font-size: 1.5rem; margin-bottom: 24px;">お問い合わせ・リクエスト一覧</h1>
      <div id="auth-form" style="text-align:center;padding:40px;">
        <input type="password" id="admin-token" placeholder="管理トークン" style="padding:10px 14px;border:2px solid var(--border);border-radius:6px;font-size:0.9rem;width:250px;">
        <button onclick="doLogin()" style="padding:10px 20px;background:var(--green-mid);color:white;border:none;border-radius:6px;font-weight:700;cursor:pointer;margin-left:8px;">表示</button>
      </div>
      <div id="loading" style="display:none;text-align:center;padding:40px;color:var(--text-mid);">読み込み中...</div>
      <div id="contacts-list"></div>
    </div>
  </section>
</BaseLayout>

<script>
function doLogin() {
  const token = (document.getElementById('admin-token') as HTMLInputElement).value;
  if (!token) return;
  document.getElementById('auth-form')!.style.display = 'none';
  document.getElementById('loading')!.style.display = 'block';
  load(token);
}

async function load(token: string) {
  try {
    const res = await fetch(`https://hojotown-api.taitatu4barisuta.workers.dev/contacts?token=${encodeURIComponent(token)}`);
    const data = await res.json();
    document.getElementById('loading')!.style.display = 'none';
    const list = document.getElementById('contacts-list')!;

    if (data.length === 0) {
      list.innerHTML = '<p style="text-align:center;color:var(--text-soft);padding:40px;">まだデータがありません</p>';
      return;
    }

    let html = `<p style="margin-bottom:16px;font-size:0.9rem;color:var(--text-mid);">${data.length}件</p>`;
    html += '<div style="display:flex;flex-direction:column;gap:12px;">';
    for (const c of data) {
      const date = new Date(c.created_at).toLocaleString('ja-JP');
      const typeLabel = c.type === 'city_request' ? '🏙️ 市リクエスト' : '✉️ お問い合わせ';
      const esc = (s: string) => s.replace(/[&<>"']/g, (c: string) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c] || c));
      html += `
        <div style="background:white;border:1px solid var(--border);border-radius:8px;padding:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
            <span style="font-size:0.8rem;font-weight:600;color:var(--green-deep);">${typeLabel}</span>
            <span style="font-size:0.75rem;color:var(--text-soft);">${date}</span>
          </div>
          ${c.name ? `<div style="font-weight:600;">${esc(c.name)}</div>` : ''}
          ${c.email ? `<div style="font-size:0.85rem;color:var(--text-mid);">${esc(c.email)}</div>` : ''}
          ${c.city ? `<div style="font-size:0.85rem;color:var(--green-deep);font-weight:600;">📍 ${esc(c.city)}</div>` : ''}
          ${c.message ? `<div style="margin-top:8px;font-size:0.9rem;white-space:pre-wrap;">${esc(c.message)}</div>` : ''}
        </div>`;
    }
    html += '</div>';
    list.innerHTML = html;
  } catch {
    document.getElementById('loading')!.style.display = 'none';
    document.getElementById('auth-form')!.style.display = 'block';
    alert('トークンが正しくありません');
  }
}
</script>
