---
import BaseLayout from '../../layouts/BaseLayout.astro';
import cities from '../../data/cities.json';
import { CATEGORY_LABELS } from '../../data/types';
import type { Category, Subsidy } from '../../data/types';
import fs from 'node:fs';
import path from 'node:path';

// 全補助金データを動的に読み込み（fsで全JSONファイルを自動収集）
const subsidiesDir = path.join(process.cwd(), 'src/data/subsidies');
const allSubsidies: Subsidy[] = [];
for (const file of fs.readdirSync(subsidiesDir).filter(f => f.endsWith('.json'))) {
  try {
    const data = JSON.parse(fs.readFileSync(path.join(subsidiesDir, file), 'utf8'));
    if (Array.isArray(data)) allSubsidies.push(...(data as Subsidy[]));
  } catch {}
}

const citiesWithData = new Set(allSubsidies.map(s => s.cityCode));
const availableCities = cities.filter(city => citiesWithData.has(city.code));

const compareCategories: { key: Category; label: string }[] = [
  { key: 'childcare', label: '子育て' },
  { key: 'birth', label: '出産支援' },
  { key: 'medical', label: '医療費助成' },
  { key: 'reform', label: '住宅リフォーム' },
  { key: 'disability', label: '障害者支援' },
  { key: 'elderly', label: '高齢者支援' },
  { key: 'solar', label: '太陽光・省エネ' },
  { key: 'fertility', label: '不妊治療' },
  { key: 'vaccine', label: '予防接種' },
];

// 全データをJSONとしてクライアントに渡す
const cityDataMap: Record<string, any> = {};
for (const city of availableCities) {
  const subs = allSubsidies.filter(s => s.cityCode === city.code && s.status === 'active');
  cityDataMap[city.code] = {
    ...city,
    subsidyCount: subs.length,
    subsidies: subs,
  };
}
---
<BaseLayout
  title="自治体の補助金を比較 - どの市が手厚い？"
  description="近隣の市区町村の補助金・助成金を横並びで比較。子育て支援、医療費助成、住宅補助など、どの自治体が手厚いかが一目でわかります。"
>
  <section class="cmp-hero">
    <div class="container">
      <h1>自治体の補助金を比較する</h1>
      <p>2〜3の市を選んで、補助金を横並びで比較できます。</p>
    </div>
  </section>

  <section class="cmp-selector">
    <div class="container">
      <div id="cmp-selects" class="cmp-selects">
        <div class="cmp-select-group">
          <label>市区町村①</label>
          <input type="text" class="cmp-search" placeholder="市名で検索..." data-for="city1" autocomplete="off">
          <select id="city1" class="cmp-select">
            <option value="">選択してください</option>
            {availableCities.map(c => (
              <option value={c.code}>{c.name}（{c.prefecture}）</option>
            ))}
          </select>
        </div>
        <div class="cmp-vs">VS</div>
        <div class="cmp-select-group">
          <label>市区町村②</label>
          <input type="text" class="cmp-search" placeholder="市名で検索..." data-for="city2" autocomplete="off">
          <select id="city2" class="cmp-select">
            <option value="">選択してください</option>
            {availableCities.map(c => (
              <option value={c.code}>{c.name}（{c.prefecture}）</option>
            ))}
          </select>
        </div>
      </div>
      <button id="add-city-btn" class="cmp-add-btn" type="button">＋ 市区町村を追加</button>
    </div>
  </section>

  <section class="cmp-result">
    <div class="container">
      <div class="cmp-table-wrap" id="cmp-table-wrap">
        <p class="cmp-empty">上のセレクタから市区町村を選んでください。</p>
      </div>

      <div class="disclaimer" style="margin-top: 24px;">
        掲載情報は各自治体の公式サイトを参考に作成しています。最新の情報は必ず各自治体の公式ホームページをご確認ください。
        <br><a href="/contact/" style="font-size:0.8rem;">情報の誤りを報告する</a>
      </div>

      <div style="text-align: center; background: var(--green-pale); margin-top: 32px; padding: 28px; border-radius: 8px;">
        <p style="font-size: 1.1rem; font-weight: 700; margin-bottom: 12px;">あなたに合った補助金を診断してみませんか？</p>
        <p style="font-size: 0.9rem; color: var(--text-mid); margin-bottom: 16px;">5つの質問に答えるだけで、もらえる補助金と合計金額がわかります。</p>
        <a href="/shindan/" class="btn btn-primary">診断してみる</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ cityDataMap, compareCategories, availableCities }}>
let cityCount = 2;

// 検索フィルタ
document.addEventListener('input', function(e) {
  if (!e.target.classList.contains('cmp-search')) return;
  const selectId = e.target.getAttribute('data-for');
  const select = document.getElementById(selectId);
  const q = e.target.value.toLowerCase();
  for (const opt of select.options) {
    if (!opt.value) continue;
    opt.style.display = opt.textContent.toLowerCase().includes(q) ? '' : 'none';
  }
});

// 市区町村追加ボタン
document.getElementById('add-city-btn').addEventListener('click', function() {
  if (cityCount >= 10) return;
  cityCount++;
  const container = document.getElementById('cmp-selects');
  const vs = document.createElement('div');
  vs.className = 'cmp-vs';
  vs.textContent = 'VS';
  container.appendChild(vs);

  const group = document.createElement('div');
  group.className = 'cmp-select-group';
  const label = document.createElement('label');
  label.textContent = '市区町村' + '①②③④⑤⑥⑦⑧⑨⑩'[cityCount-1];
  const search = document.createElement('input');
  search.type = 'text';
  search.className = 'cmp-search';
  search.placeholder = '市名で検索...';
  search.setAttribute('data-for', 'city' + cityCount);
  search.autocomplete = 'off';
  const select = document.createElement('select');
  select.id = 'city' + cityCount;
  select.className = 'cmp-select';
  select.innerHTML = '<option value="">選択してください</option>' +
    availableCities.map(c => '<option value="' + c.code + '">' + c.name + '（' + c.prefecture + '）</option>').join('');
  select.addEventListener('change', render);
  group.appendChild(label);
  group.appendChild(search);
  group.appendChild(select);
  container.appendChild(group);

  if (cityCount >= 10) this.style.display = 'none';
});

function render() {
  const codes = [];
  for (let i = 1; i <= cityCount; i++) {
    const el = document.getElementById('city' + i);
    if (el && el.value) codes.push(el.value);
  }
  const wrap = document.getElementById('cmp-table-wrap');

  if (codes.length < 2) {
    wrap.innerHTML = '<p class="cmp-empty">2つ以上の市区町村を選んでください。</p>';
    return;
  }

  const selected = codes.map(code => cityDataMap[code]).filter(Boolean);
  if (selected.length < 2) {
    wrap.innerHTML = '<p class="cmp-empty">データがありません。</p>';
    return;
  }

  const esc = s => String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

  let html = '<table class="compare-table"><thead><tr><th>項目</th>';
  for (const c of selected) {
    html += `<th><a href="/${esc(c.prefectureSlug)}/${esc(c.slug)}/" style="color:white;text-decoration:underline">${esc(c.name)}</a></th>`;
  }
  html += '</tr></thead><tbody>';

  // 人口
  html += '<tr><td>人口</td>';
  for (const c of selected) html += `<td>${(c.population/10000).toFixed(1)}万人</td>`;
  html += '</tr>';

  // 制度数（最多をハイライト）
  html += '<tr><td>掲載制度数</td>';
  const maxCount = Math.max(...selected.map(c => c.subsidyCount));
  for (const c of selected) {
    const best = c.subsidyCount === maxCount && selected.filter(s => s.subsidyCount === maxCount).length < selected.length;
    html += `<td class="${best ? 'highlight best' : 'highlight'}">${c.subsidyCount}件</td>`;
  }
  html += '</tr>';

  // カテゴリ別（制度数が多い方をハイライト）
  for (const cat of compareCategories) {
    const catData = selected.map(c => {
      const subs = c.subsidies.filter(s => s.category === cat.key);
      return { subs, count: subs.length };
    });
    if (catData.every(d => d.count === 0)) continue;

    const maxCat = Math.max(...catData.map(d => d.count));
    html += `<tr><td>${esc(cat.label)}</td>`;
    for (const d of catData) {
      const isBest = d.count === maxCat && d.count > 0 && catData.filter(x => x.count === maxCat).length < catData.length;
      if (d.count > 0) {
        html += `<td class="${isBest ? 'best' : ''}">`;
        for (const s of d.subs) {
          html += `<div class="compare-subsidy"><span class="compare-subsidy-name">${esc(s.name)}</span><span class="compare-subsidy-amount">${esc(s.amount)}</span></div>`;
        }
        html += '</td>';
      } else {
        html += '<td><span class="compare-none">—</span></td>';
      }
    }
    html += '</tr>';
  }

  html += '</tbody></table>';
  wrap.innerHTML = html;
}

document.getElementById('city1').addEventListener('change', render);
document.getElementById('city2').addEventListener('change', render);

</script>

<style>
  .cmp-hero {
    background: linear-gradient(135deg, #0d3320 0%, var(--green-deep) 40%, var(--green-mid) 100%);
    color: white;
    padding: 40px 0;
    text-align: center;
  }
  .cmp-hero h1 { font-size: 1.8rem; font-weight: 700; margin-bottom: 8px; }
  .cmp-hero p { opacity: 0.85; font-size: 1rem; }

  .cmp-selector {
    background: white;
    padding: 32px 0;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 44px;
    z-index: 50;
  }
  .cmp-selects {
    display: flex;
    align-items: end;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cmp-select-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cmp-select-group label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-mid);
  }
  .cmp-select {
    padding: 10px 16px;
    border: 2px solid var(--border);
    border-radius: 6px;
    font-size: 0.9rem;
    font-family: inherit;
    min-width: 200px;
    background: white;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .cmp-select:focus {
    border-color: var(--green-mid);
    outline: none;
  }
  .cmp-search {
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
    margin-bottom: 4px;
  }
  .cmp-search:focus { border-color: var(--green-mid); outline: none; }
  .cmp-add-btn {
    display: block;
    margin: 12px auto 0;
    padding: 8px 20px;
    background: white;
    border: 2px dashed var(--border);
    border-radius: 6px;
    color: var(--text-mid);
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
  }
  .cmp-add-btn:hover { border-color: var(--green-mid); color: var(--green-deep); }
  .cmp-vs {
    font-weight: 700;
    color: var(--gold);
    font-size: 1.1rem;
    padding-bottom: 10px;
  }

  .cmp-result {
    padding: 32px 0 48px;
  }
  .cmp-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .cmp-empty {
    text-align: center;
    color: var(--text-soft);
    padding: 48px 0;
    font-size: 0.95rem;
  }

  .compare-subsidy { padding: 4px 0; border-bottom: 1px solid #f0f0ea; }
  .compare-subsidy:last-child { border-bottom: none; }
  .compare-subsidy-name { display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-dark); }
  .compare-subsidy-amount { display: block; font-size: 0.75rem; color: var(--green-deep); font-weight: 700; }
  .compare-none { color: var(--text-soft); font-size: 0.85rem; }
  .best { background: rgba(26, 92, 58, 0.08); border-left: 3px solid var(--green-mid); }
  .best.highlight { color: var(--green-deep); font-weight: 800; }

  @media (max-width: 768px) {
    .cmp-selects { flex-direction: column; align-items: stretch; }
    .cmp-select { min-width: 100%; }
    .cmp-vs { text-align: center; padding: 4px 0; }
    .cmp-hero h1 { font-size: 1.4rem; }
  }
</style>
