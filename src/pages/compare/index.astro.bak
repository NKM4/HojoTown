---
import BaseLayout from '../../layouts/BaseLayout.astro';
import cities from '../../data/cities.json';
import kawagoeData from '../../data/subsidies/kawagoe.json';
import { CATEGORY_LABELS } from '../../data/types';
import type { Category, Subsidy } from '../../data/types';

import saitamaData from '../../data/subsidies/saitama.json';
import tokorozawaData from '../../data/subsidies/tokorozawa.json';
import kawaguchiData from '../../data/subsidies/kawaguchi.json';
import yokohamaData from '../../data/subsidies/yokohama.json';
import nagoyaData from '../../data/subsidies/nagoya.json';
import sendaiData from '../../data/subsidies/sendai.json';
import osakaData from '../../data/subsidies/osaka.json';
import kobeData from '../../data/subsidies/kobe.json';
import kyotoData from '../../data/subsidies/kyoto.json';
import fukuokaData from '../../data/subsidies/fukuoka.json';
import kawasakiData from '../../data/subsidies/kawasaki.json';
import chibaData from '../../data/subsidies/chiba.json';
import hiroshimaData from '../../data/subsidies/hiroshima.json';
import kumamotoData from '../../data/subsidies/kumamoto.json';
import kagoshimaData from '../../data/subsidies/kagoshima.json';
import nahaData from '../../data/subsidies/naha.json';
import sagamiharaData from '../../data/subsidies/sagamihara.json';
import hamamatsuData from '../../data/subsidies/hamamatsu.json';
import shizuokaData from '../../data/subsidies/shizuoka.json';
import niigataData from '../../data/subsidies/niigata.json';
import sakaiData from '../../data/subsidies/sakai.json';
import okayamaData from '../../data/subsidies/okayama.json';
import sapporoData from '../../data/subsidies/sapporo.json';
import kitakyushuData from '../../data/subsidies/kitakyushu.json';
import matsuyamaData from '../../data/subsidies/matsuyama.json';
import takamatsuData from '../../data/subsidies/takamatsu.json';
import fujiminoData from '../../data/subsidies/fujimino.json';

// 全市のデータを統合
const allSubsidies: Subsidy[] = [
  ...kawagoeData as Subsidy[],
  ...saitamaData as Subsidy[],
  ...tokorozawaData as Subsidy[],
  ...kawaguchiData as Subsidy[],
  ...yokohamaData as Subsidy[],
  ...nagoyaData as Subsidy[],
  ...sendaiData as Subsidy[],
  ...osakaData as Subsidy[],
  ...kobeData as Subsidy[],
  ...kyotoData as Subsidy[],
  ...fukuokaData as Subsidy[],
  ...kawasakiData as Subsidy[],
  ...chibaData as Subsidy[],
  ...hiroshimaData as Subsidy[],
  ...kumamotoData as Subsidy[],
  ...kagoshimaData as Subsidy[],
  ...nahaData as Subsidy[],
  ...sagamiharaData as Subsidy[],
  ...hamamatsuData as Subsidy[],
  ...shizuokaData as Subsidy[],
  ...niigataData as Subsidy[],
  ...sakaiData as Subsidy[],
  ...okayamaData as Subsidy[],
  ...sapporoData as Subsidy[],
  ...kitakyushuData as Subsidy[],
  ...matsuyamaData as Subsidy[],
  ...takamatsuData as Subsidy[],
  ...fujiminoData as Subsidy[],
];

// データがある市のコードを抽出
const citiesWithData = new Set(allSubsidies.map(s => s.cityCode));

// 比較用の集計データを事前計算（データがある市のみ）
const cityStats = cities.filter(city => citiesWithData.has(city.code)).map(city => {
  const subs = allSubsidies.filter(s => s.cityCode === city.code && s.status === 'active');
  const categories = [...new Set(subs.map(s => s.category))];
  const totalMax = subs.reduce((sum, s) => sum + s.maxAmount, 0);
  return {
    ...city,
    subsidyCount: subs.length,
    categories,
    totalMaxAmount: totalMax,
    subsidies: subs,
  };
});

// 比較用カテゴリ（主要なもの）
const compareCategories: { key: Category; label: string }[] = [
  { key: 'childcare', label: '子育て' },
  { key: 'birth', label: '出産支援' },
  { key: 'medical', label: '医療費助成' },
  { key: 'reform', label: '住宅リフォーム' },
  { key: 'disability', label: '障害者支援' },
  { key: 'elderly', label: '高齢者支援' },
  { key: 'solar', label: '太陽光・省エネ' },
  { key: 'school_meal', label: '学校給食' },
  { key: 'fertility', label: '不妊治療' },
  { key: 'vaccine', label: '予防接種' },
];
---
<BaseLayout
  title="自治体の補助金を比較 - どの市が手厚い？"
  description="近隣の市区町村の補助金・助成金を横並びで比較。子育て支援、医療費助成、住宅補助など、どの自治体が手厚いかが一目でわかります。"
>
  <section class="hero" style="padding: 32px 0;">
    <div class="container">
      <h1 style="font-size: 1.8rem;">自治体の補助金を比較する</h1>
      <p>近隣の市を横並びで比較。どの市が手厚いかが一目でわかります。</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {/* 概要比較 */}
      <h2 class="section-title">対応市区町村の比較</h2>
      <div class="compare-scroll">
        <table class="compare-table">
          <thead>
            <tr>
              <th>項目</th>
              {cityStats.map(city => (
                <th>
                  <a href={`/${city.prefectureSlug}/${city.slug}/`} style="color: white; text-decoration: underline;">
                    {city.name}
                  </a>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>人口</td>
              {cityStats.map(city => (
                <td>{(city.population / 10000).toFixed(1)}万人</td>
              ))}
            </tr>
            <tr>
              <td>掲載制度数</td>
              {cityStats.map(city => (
                <td class={city.subsidyCount > 0 ? 'highlight' : ''}>
                  {city.subsidyCount > 0 ? `${city.subsidyCount}件` : '準備中'}
                </td>
              ))}
            </tr>
            {compareCategories.map(cat => {
              // 各市のこのカテゴリの制度をまとめる
              const cityData = cityStats.map(city => {
                const subs = city.subsidies.filter(s => s.category === cat.key);
                return { city, subs, count: subs.length };
              });

              // 全市で0件のカテゴリはスキップ
              if (cityData.every(d => d.count === 0)) return null;

              return (
                <tr>
                  <td>{cat.label}</td>
                  {cityData.map(d => (
                    <td>
                      {d.count > 0 ? (
                        <div>
                          {d.subs.map(s => (
                            <div class="compare-subsidy">
                              <span class="compare-subsidy-name">{s.name}</span>
                              <span class="compare-subsidy-amount">{s.amount}</span>
                            </div>
                          ))}
                        </div>
                      ) : (
                        <span class="compare-none">—</span>
                      )}
                    </td>
                  ))}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <div class="disclaimer" style="margin-top: 24px;">
        掲載情報は各自治体の公式サイトを参考に作成しています。最新の情報は必ず各自治体の公式ホームページをご確認ください。データのない市は順次追加していきます。
      </div>

      {/* CTA */}
      <div class="card" style="text-align: center; background: var(--green-pale); margin-top: 32px; padding: 28px;">
        <p style="font-size: 1.1rem; font-weight: 700; margin-bottom: 12px;">あなたに合った補助金を診断してみませんか？</p>
        <p style="font-size: 0.9rem; color: var(--text-mid); margin-bottom: 16px;">5つの質問に答えるだけで、もらえる補助金と合計金額がわかります。</p>
        <a href="/shindan/" class="btn btn-primary">診断してみる</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .compare-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    min-width: 700px;
  }
  .compare-table td {
    vertical-align: top;
  }
  .compare-subsidy {
    padding: 4px 0;
    border-bottom: 1px solid #f0f0ea;
  }
  .compare-subsidy:last-child {
    border-bottom: none;
  }
  .compare-subsidy-name {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-dark);
  }
  .compare-subsidy-amount {
    display: block;
    font-size: 0.75rem;
    color: var(--green-deep);
    font-weight: 700;
  }
  .compare-none {
    color: var(--text-soft);
    font-size: 0.85rem;
  }
</style>
