---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="baby"
  heroTitle="子どもが生まれる前に、もらえるお金を全部チェック"
  heroSubtitle="出産祝い金・児童手当・医療費助成・不妊治療助成など、子育て家庭が使える補助金は想像以上にたくさんあります。"
  subsidyIntro="出産・子育て・医療費・不妊治療に関する補助金をまとめて確認できます。自治体ごとに内容が異なるため、比較がおすすめです。"
  guideSections={[
    { title: "妊娠中に制度を確認", body: "妊婦健診助成、出産応援給付、産前産後の保険料免除などは、出産前から手続きが始まるものがあります。" },
    { title: "出生後15日以内を優先", body: "児童手当や子ども医療費助成は、出生届とあわせて早めに申請すると支給漏れを防ぎやすくなります。" },
    { title: "保育料・給食費も見る", body: "自治体によって第2子以降の保育料、給食費、ファミリーサポート利用料の助成が用意されています。" }
  ]}
  checklist={[
    "母子健康手帳と妊婦健診受診票を確認する",
    "出生届、健康保険証、口座情報を用意する",
    "所得制限と対象年齢を確認する",
    "転入した場合は前住所地との重複・空白期間を確認する"
  ]}
  caution="子育て系の制度は、申請月の翌月から支給になるものが多めです。迷ったら先に自治体窓口へ出して、不足書類を後追いで補う流れが安全です。"
  simExample={{
    label: "例：出産〜1歳までにもらえるお金",
    before: "出産費用 約50万円",
    subsidy: "出産一時金50万円 + 祝い金5万円",
    after: "実質ほぼ0円"
  }}
  nextStepTitle="お金のプロに無料で相談しよう"
  metaDescription="出産・子育てで使える補助金を一覧で確認。出産祝い金・児童手当・医療費助成など、あなたの市の制度を30秒で診断。"
/>
