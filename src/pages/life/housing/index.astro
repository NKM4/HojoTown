---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="housing"
  heroTitle="家を建てるなら、補助金を使わないと損"
  heroSubtitle="子育てエコホーム支援事業など、新築住宅で使える補助金は最大100万円以上。知らないだけで損しているかも。"
  subsidyIntro="注文住宅・建売住宅の取得に使える補助金、住宅ローン減税、太陽光パネル設置補助金などをまとめて確認できます。"
  guideSections={[
    { title: "世帯条件を先に確認", body: "子育て世帯、若者夫婦世帯、移住世帯など、対象者の条件で使える制度が変わります。" },
    { title: "住宅性能を設計に反映", body: "ZEH、長期優良住宅、省エネ基準などは設計段階で決まります。後から補助金仕様に変えると高くつきます。" },
    { title: "自治体の上乗せを探す", body: "国の住宅補助に加えて、太陽光、蓄電池、移住、三世代同居などの自治体補助が重なることがあります。" }
  ]}
  checklist={[
    "建築予定地の自治体制度を確認する",
    "住宅性能証明の取得時期を確認する",
    "契約日・着工日・引渡日の期限を確認する",
    "ローン減税や贈与非課税との関係を整理する"
  ]}
  caution="住宅系の補助金は、制度の予約枠や工事完了期限が決まっていることがあります。土地探しと同時に補助金条件を見ておくのが安全です。"
  simExample={{
    label: "例：注文住宅の新築（子育て世帯）",
    before: "3,500万円",
    subsidy: "最大100万円",
    after: "3,400万円"
  }}
  nextStepTitle="間取りプランと資金計画を無料で取り寄せ"
  metaDescription="注文住宅の補助金を活用して賢く家を建てる。子育てエコホーム支援事業など使える制度と無料の間取りプランをご紹介。"
/>
