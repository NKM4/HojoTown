---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="moving"
  heroTitle="引っ越し先の補助金、比較してから決めよう"
  heroSubtitle="移住支援金は最大100万円。引っ越し先を決める前に、自治体ごとの補助金を比較しませんか？"
  subsidyIntro="移住支援金・引越し補助金・住宅取得補助など、引っ越しに使える制度をまとめて確認できます。"
  guideSections={[
    { title: "転入前に条件を見る", body: "移住支援金は、転入前の居住地、就業先、世帯構成で対象可否が決まることがあります。" },
    { title: "仕事と住まいをセットで確認", body: "対象法人への就職、テレワーク、起業、住宅取得など、制度ごとに必要な証明書が違います。" },
    { title: "定住条件を確認", body: "一定年数住み続ける条件がある制度では、短期転出時に返還が必要になる場合があります。" }
  ]}
  checklist={[
    "転入前に事前相談が必要か確認する",
    "住民票の異動日と申請期限を確認する",
    "就業証明書・賃貸契約書・売買契約書を用意する",
    "返還条件と定住年数を確認する"
  ]}
  caution="移住系の補助金は、引っ越してから気づくと対象外になることがあります。候補地を決める前に制度条件を比較するのが安全です。"
  simExample={{
    label: "例：東京23区から地方へ移住（単身）",
    before: "引越し費用 30万円",
    subsidy: "移住支援金 最大60万円",
    after: "プラス30万円"
  }}
  nextStepTitle="引越しの準備を始めよう"
  metaDescription="引っ越し・移住で使える補助金を比較。移住支援金最大100万円など、自治体ごとの制度を確認して賢く引っ越し。"
/>
