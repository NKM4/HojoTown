---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="energy"
  heroTitle="太陽光・蓄電池・EV、補助金でお得に乗り換え"
  heroSubtitle="太陽光パネルや蓄電池の導入、EV・電動車への買い替えには国と自治体の補助金が使えます。旧車の売却額と合わせれば大幅節約。"
  subsidyIntro="太陽光発電・蓄電池・EV購入補助・EV充電設備・省エネ家電の買い替えに使える補助金をまとめて確認できます。"
  guideSections={[
    { title: "設備ごとに制度を分ける", body: "太陽光、蓄電池、V2H、EV、省エネ家電は窓口や申請時期が違います。まとめて入れる前に制度別に確認します。" },
    { title: "見積もりは複数取る", body: "補助金額より本体価格の差が大きいことがあります。補助金対応の可否も含めて比較します。" },
    { title: "導入後の条件も確認", body: "発電量報告、処分制限、リース可否など、導入後の条件が付く制度があります。" }
  ]}
  checklist={[
    "対象メーカー・型番・性能要件を確認する",
    "契約前申請か設置後申請か確認する",
    "国補助と自治体補助の併用可否を確認する",
    "電気料金削減額と初期費用の回収年数を見る"
  ]}
  caution="省エネ系は申請枠の消化が早く、型番違いで対象外になるケースがあります。見積書に型番まで入れて確認するのが大事です。"
  simExample={{
    label: "例：太陽光パネル+蓄電池の導入",
    before: "250万円",
    subsidy: "国+市で最大70万円",
    after: "180万円"
  }}
  nextStepTitle="見積もり・査定で実質負担額を確認"
  metaDescription="太陽光パネル・蓄電池・EV購入の補助金を一覧で確認。国と自治体の補助金+旧車売却で大幅節約。無料見積もり。"
/>
