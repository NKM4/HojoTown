---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="funeral"
  heroTitle="家族が亡くなったとき、申請できるお金"
  heroSubtitle="葬祭費補助・遺族年金・高額療養費の還付など、知らないと申請しそびれる制度があります。"
  subsidyIntro="葬祭費補助金・埋葬料・遺族年金・相続に関する手続きなど、必要な制度をまとめて確認できます。"
  guideSections={[
    { title: "健康保険の給付を確認", body: "国民健康保険は葬祭費、会社員の健康保険は埋葬料など、加入していた保険で申請先が変わります。" },
    { title: "年金・医療費を整理", body: "未支給年金、高額療養費、介護保険料の還付など、死亡後に戻るお金があります。" },
    { title: "期限の短い手続きを優先", body: "世帯主変更、保険証返却、公共料金、相続放棄など、期限のある手続きから順に進めます。" }
  ]}
  checklist={[
    "死亡診断書のコピーを保管する",
    "故人の健康保険・年金の種類を確認する",
    "葬儀費用の領収書を保管する",
    "相続放棄や準確定申告の期限を確認する"
  ]}
  caution="葬祭費や埋葬料は自動では振り込まれません。喪主または葬祭を行った人が、加入していた保険者へ申請する必要があります。"
  simExample={{
    label: "例：国民健康保険の葬祭費",
    before: "葬儀費用 150万円",
    subsidy: "葬祭費 5〜7万円",
    after: "143〜145万円"
  }}
  nextStepTitle="必要な手続きを確認しよう"
  metaDescription="家族が亡くなったときに申請できる補助金・給付金を確認。葬祭費補助・遺族年金・相続手続きをわかりやすく解説。"
/>
