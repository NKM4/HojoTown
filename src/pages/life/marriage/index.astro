---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="marriage"
  heroTitle="結婚したら使える支援金、知っていますか？"
  heroSubtitle="結婚新生活支援事業は最大60万円。新居の家賃・引越し費用を自治体が補助してくれます。"
  subsidyIntro="結婚新生活支援金・新婚世帯向け住宅補助・引越し補助など、結婚に関する支援制度をまとめて確認できます。"
  guideSections={[
    { title: "婚姻日と年齢条件を確認", body: "結婚新生活支援は、夫婦の年齢、所得、婚姻日、申請時点の住所で対象が決まります。" },
    { title: "対象経費を分けて保存", body: "家賃、敷金礼金、仲介手数料、引越し費用など、対象になる領収書を分けて保管します。" },
    { title: "年度内の支払いに注意", body: "補助対象は年度内に支払った費用に限られる場合があります。入居時期と支払い日を確認します。" }
  ]}
  checklist={[
    "婚姻届受理証明書または戸籍謄本を用意する",
    "夫婦の所得証明書を確認する",
    "賃貸借契約書と領収書を保管する",
    "自治体の申請期限と予算残額を確認する"
  ]}
  caution="結婚支援金は実施していない自治体もあります。新居の候補地が複数ある場合は、補助金の有無も比較材料になります。"
  simExample={{
    label: "例：結婚に伴う新生活の初期費用",
    before: "家賃+引越し 50万円",
    subsidy: "結婚新生活支援金 最大60万円",
    after: "実質0円"
  }}
  nextStepTitle="結婚の準備を始めよう"
  metaDescription="結婚で使える補助金を一覧で確認。結婚新生活支援事業で最大60万円の補助。あなたの市の支援制度を診断。"
/>
