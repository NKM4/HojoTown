---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="reform"
  heroTitle="リフォーム補助金を使って、賢く家を直す"
  heroSubtitle="自治体のリフォーム補助金を活用すれば、数万円〜数十万円の節約に。まずはあなたの市の補助金を確認しましょう。"
  subsidyIntro="住宅リフォーム・外壁塗装・バリアフリー改修・空き家改修など、リフォームに使える補助金をまとめて確認できます。"
  guideSections={[
    { title: "契約前に対象工事を確認", body: "多くの補助金は、交付決定前に契約・着工すると対象外になります。見積もり段階で制度名を業者に共有します。" },
    { title: "市内業者条件を見る", body: "自治体によっては市内施工業者、耐震診断済み、築年数などの条件があります。金額だけでなく条件を先に見ます。" },
    { title: "国制度との併用を確認", body: "省エネ改修、窓断熱、バリアフリーは国の補助と自治体補助を併用できる場合があります。" }
  ]}
  checklist={[
    "契約・着工前に申請が必要か確認する",
    "見積書、工事図面、施工前写真を保存する",
    "市税滞納なしなど世帯条件を確認する",
    "予算上限到達による早期終了を確認する"
  ]}
  caution="リフォーム補助金は年度途中で予算終了しやすい分野です。公式ページが受付中でも、申請前に残額確認をすると手戻りが減ります。"
  simExample={{
    label: "例：浴室+キッチンのリフォーム",
    before: "200万円",
    subsidy: "最大20万円",
    after: "180万円"
  }}
  nextStepTitle="まずは無料で見積もりを取ろう"
  metaDescription="リフォーム補助金を活用してお得にリフォーム。あなたの市の補助金額と、無料見積もりで実質負担額がわかります。"
/>
