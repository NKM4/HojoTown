---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="career"
  heroTitle="仕事を辞める・変えるとき、使える給付金"
  heroSubtitle="教育訓練給付金を使えば、プログラミングスクールや資格講座の受講料が最大70%戻ってきます。転職・スキルアップを公的制度が支援。"
  subsidyIntro="教育訓練給付金（一般/特定一般/専門実践）・資格取得支援・就業支援など、キャリアチェンジに使える制度をまとめて確認できます。"
  guideSections={[
    { title: "対象講座を先に確認", body: "教育訓練給付金は厚生労働大臣指定講座が対象です。似た講座名でも対象外のことがあります。" },
    { title: "受講前手続きを確認", body: "専門実践教育訓練は、受講開始前にキャリアコンサルティングやジョブカードが必要な場合があります。" },
    { title: "失業給付との関係を見る", body: "退職後に学ぶ場合は、雇用保険の受給、受講開始日、就職活動実績を一緒に確認します。" }
  ]}
  checklist={[
    "雇用保険の加入期間を確認する",
    "講座が給付金指定講座か確認する",
    "受講開始前の手続き期限を確認する",
    "修了証明書と領収書の発行条件を確認する"
  ]}
  caution="給付金は受講すれば必ず出るものではありません。対象講座、本人の雇用保険条件、修了要件の3つを先に確認してください。"
  simExample={{
    label: "例：専門実践教育訓練（プログラミングスクール等）",
    before: "受講費 60万円",
    subsidy: "教育訓練給付金 最大70%",
    after: "18万円"
  }}
  nextStepTitle="給付金対象のスクール・講座を探そう"
  metaDescription="転職・退職時に使える給付金を確認。教育訓練給付金で最大70%補助、失業給付の受給条件など。"
/>
