---
import LifeEventLP from '../../../components/LifeEventLP.astro';
import ArticleAds from '../../../components/ArticleAds.astro';
---
<LifeEventLP
  event="retirement"
  heroTitle="老後に使える補助金・支援制度を全部確認"
  heroSubtitle="介護保険・高齢者向け住宅改修・医療費助成・免許返納支援など、シニア世代の生活を支える制度は多数あります。"
  subsidyIntro="高齢者支援・介護サービス・医療費助成・バリアフリー改修・免許返納支援などの制度をまとめて確認できます。"
  guideSections={[
    { title: "介護認定の有無を確認", body: "住宅改修や福祉用具は、要介護・要支援認定が前提になることがあります。先に認定状況を確認します。" },
    { title: "医療費と介護費を分けて見る", body: "高額療養費、高額介護サービス費、自治体の医療費助成は窓口が異なるため、別々に確認します。" },
    { title: "家族で書類を管理", body: "本人確認、委任状、口座、介護保険証など、家族が代行する場合に必要な書類を早めにそろえます。" }
  ]}
  checklist={[
    "介護保険証と負担割合証を確認する",
    "工事前申請が必要な住宅改修か確認する",
    "医療費の領収書を月ごとに保管する",
    "免許返納や交通助成の対象年齢を確認する"
  ]}
  caution="介護・高齢者支援は、ケアマネジャー経由で進めたほうが通りやすい手続きがあります。工事や購入の前に相談しておくと安心です。"
  simExample={{
    label: "例：バリアフリー改修（介護保険+自治体補助）",
    before: "改修費用 80万円",
    subsidy: "介護保険20万円 + 市補助10万円",
    after: "50万円"
  }}
  nextStepTitle="まずは情報を集めよう"
  metaDescription="老後・介護に使える補助金を一覧で確認。介護保険・高齢者住宅改修・医療費助成など、シニア向け支援制度を網羅。"
/>
