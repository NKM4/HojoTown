import BaseLayout from '../layouts/BaseLayout.astro';
import cities from '../data/cities.json';
import fs from 'node:fs';
import path from 'node:path';

// データがある市だけ抽出
const subsidiesDir = path.join(process.cwd(), 'src/data/subsidies');
const dataSlugs = new Set(
  fs.readdirSync(subsidiesDir)
    .filter(f => f.endsWith('.json'))
    .map(f => f.replace('.json', ''))
    .filter(slug => {
      try {
        const data = JSON.parse(fs.readFileSync(path.join(subsidiesDir, slug + '.json'), 'utf8'));
        return Array.isArray(data) && data.length > 0;
      } catch { return false; }
    })
);
const activeCities = cities.filter(c => dataSlugs.has(c.slug));
const totalSubsidies = Array.from(dataSlugs).reduce((sum, slug) => {
  try {
    return sum + JSON.parse(fs.readFileSync(path.join(subsidiesDir, slug + '.json'), 'utf8')).length;
  } catch { return sum; }
}, 0);

// トップ比較表用データ（3大都市）
const compareSlugs = ['setagaya', 'osaka', 'nagoya'];
const compareData = compareSlugs.map(slug => {
  const city = cities.find(c => c.slug === slug);
  try {
    const subs = JSON.parse(fs.readFileSync(path.join(subsidiesDir, slug + '.json'), 'utf8'));
    const active = subs.filter((s: any) => s.status === 'active');
    const findByCategory = (cat: string) => active.filter((s: any) => s.category === cat);
    const medical = findByCategory('medical')[0];
    const childcare = findByCategory('childcare')[0];
    const reform = findByCategory('reform')[0];
    return {
      name: city?.name || slug,
      medical: medical?.amount || '—',
      childcare: childcare?.amount || '—',
      reform: reform?.amount || '—',
      count: active.length,
    };
  } catch { return { name: slug, medical: '—', childcare: '—', reform: '—', count: 0 }; }
});

// クライアント用都市データ（位置情報判定用）
const clientCities = activeCities.map(c => ({ code: c.code, name: c.name, slug: c.slug, pref: c.prefectureSlug }));

// 地域ごとにグループ（データがある市のみ）
const regions = [
  { name: '北海道・東北', cities: activeCities.filter(c => ['hokkaido','miyagi','aomori','iwate','akita','yamagata','fukushima'].includes(c.prefectureSlug)) },
  { name: '関東', cities: activeCities.filter(c => ['saitama','chiba','kanagawa','tokyo','ibaraki','tochigi','gunma'].includes(c.prefectureSlug)) },
  { name: '中部', cities: activeCities.filter(c => ['niigata','shizuoka','aichi','nagano','toyama','ishikawa','fukui','yamanashi','gifu'].includes(c.prefectureSlug)) },
  { name: '近畿', cities: activeCities.filter(c => ['kyoto','osaka','hyogo','nara','shiga','wakayama','mie'].includes(c.prefectureSlug)) },
  { name: '中国・四国', cities: activeCities.filter(c => ['okayama','hiroshima','kagawa','ehime','tottori','shimane','yamaguchi','tokushima','kochi'].includes(c.prefectureSlug)) },
  { name: '九州・沖縄', cities: activeCities.filter(c => ['fukuoka','kumamoto','kagoshima','okinawa','saga','nagasaki','oita','miyazaki'].includes(c.prefectureSlug)) },
].filter(r => r.cities.length > 0);
