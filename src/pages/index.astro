function dist(lat1,lng1,lat2,lng2) {
  const R=6371;
  const d=Math.PI/180;
  const a=Math.sin((lat2-lat1)*d/2)**2+Math.cos(lat1*d)*Math.cos(lat2*d)*Math.sin((lng2-lng1)*d/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

function findNearest(lat,lng) {
  let min=Infinity, best=null;
  for(const c of CITIES) {
    const d=dist(lat,lng,c.lat,c.lng);
    if(d<min){min=d;best=c;}
  }
  return {city:best, distance:min};
}

document.addEventListener('DOMContentLoaded', () => {
  if (!navigator.geolocation) return;
  if (sessionStorage.getItem('geo_done')) return;

  const result = document.getElementById('geo-result');

  // ページ読み込み時に自動で位置情報を要求
  navigator.geolocation.getCurrentPosition(
      async (pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;
        let city = null;
        let distance = 0;

        // 1. 逆ジオコーディングで正確な市区町村コードを取得
        let detectedCode = '';
        try {
          const res = await fetch(`https://mreversegeocoder.gsi.go.jp/reverse-geocoder/LonLatToAddress?lat=${lat}&lon=${lng}`);
          const data = await res.json();
          if (data.results && data.results.muniCd) {
            detectedCode = data.results.muniCd;
            city = clientCities.find(c => c.code === detectedCode);
            if (city) {
              // CITIESリストにlat/lngがないのでダミーで距離0にする
              city = { ...city, lat: lat, lng: lng };
            }
          }
        } catch {}

        // 2. 逆ジオコーディング失敗時はfallbackで最寄り判定
        if (!city) {
          const nearest = findNearest(lat, lng);
          city = nearest.city;
          distance = nearest.distance;
          if (distance >= 50) city = null;
        } else {
          distance = dist(lat, lng, city.lat, city.lng);
        }

        if (city) {
          result.style.display = 'block';
          const esc = s => s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
          const n = esc(city.name);
          result.innerHTML = `
            <p class="hp-geo-detected">📍 ${n}にお住まいですね</p>
            <div class="hp-geo-actions">
              <a href="/${city.pref}/${city.slug}/" class="hp-geo-link">${n}の補助金を見る →</a>
              <a href="/shindan/" class="hp-geo-link">この街で診断する →</a>
            </div>
          `;
        } else {
          // 未対応地域 → 最寄りの対応都市を提案
          const nearest = findNearest(lat, lng);
          result.style.display = 'block';
          const esc = s => s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
          const muniDisplay = 'お住まいの地域';

          result.innerHTML = `
            <p class="hp-geo-detected">📍 ${muniDisplay}にお住まいですね</p>
            <p style="font-size:0.9rem;color:var(--text-mid);margin-top:4px;">この市のデータは現在準備中です</p>
            <div class="hp-geo-actions">
              <button onclick="requestCity('${detectedMuni || 'unknown'}')" class="hp-geo-link" style="border:2px solid var(--green-mid);background:var(--green-mid);color:white;cursor:pointer;font-weight:700;">この市のデータをリクエスト</button>
              <a href="/shindan/" class="hp-geo-link">他の市で診断する →</a>
            </div>
          `;
        }
        // GA4カスタムイベント: 位置情報
        if (typeof gtag === 'function') {
          gtag('event', 'geolocation_detected', {
            matched_city: city ? city.name : 'none',
            distance_km: Math.round(distance * 10) / 10,
            latitude: Math.round(pos.coords.latitude * 100) / 100,
            longitude: Math.round(pos.coords.longitude * 100) / 100,
          });
        }

        sessionStorage.setItem('geo_done', '1');
      },
      () => {
        sessionStorage.setItem('geo_done', '1');
      },
      { timeout: 8000 }
    );
});
</script>

