---
import { getMatchingAds } from '../data/affiliate';

interface Props {
  categories: string[];
}

const { categories } = Astro.props;
const ads = getMatchingAds(categories);
---

{ads.length > 0 && (
  <div class="article-ads">
    <p class="article-ads-label">関連サービス</p>
    {ads.map((ad, i) => (
      <a
        href={ad.url}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="article-ad-card"
        data-ad-id={ad.id}
        data-position={i + 1}
      >
        <span class="article-ad-pr">PR</span>
        <div class="article-ad-body">
          <span class="article-ad-icon">{ad.icon}</span>
          <div>
            <h4 class="article-ad-title">{ad.title}</h4>
            <p class="article-ad-desc">{ad.description}</p>
            <span class="article-ad-badge">無料で相談可能</span>
          </div>
        </div>
        <span class="article-ad-cta">{ad.ctaText} →</span>
      </a>
    ))}
  </div>
)}

<script>
  document.querySelectorAll('.article-ad-card[data-ad-id]').forEach((el) => {
    el.addEventListener('click', () => {
      if (typeof gtag === 'function') {
        gtag('event', 'affiliate_click', {
          ad_id: el.getAttribute('data-ad-id'),
          source: 'article_ad',
          position: Number(el.getAttribute('data-position')),
        });
      }
    });
  });
</script>

<style is:global>
  .article-ads {
    margin: 32px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .article-ads-label {
    font-size: 0.75rem;
    color: var(--text-soft);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .article-ad-card {
    display: block;
    background: linear-gradient(135deg, #fffdf5 0%, #fff8e8 100%);
    border: 2px solid #e8c84a;
    border-radius: 14px;
    padding: 20px 22px;
    text-decoration: none;
    color: var(--text-dark);
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
  }
  .article-ad-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, #c8a84b, #e8c84a, #c8a84b);
  }
  .article-ad-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(200, 168, 75, 0.2);
    text-decoration: none;
  }
  .article-ad-pr {
    position: absolute;
    top: 10px; right: 12px;
    font-size: 0.6rem;
    color: #b8960a;
    background: rgba(232,200,74,0.15);
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 700;
  }
  .article-ad-body {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-bottom: 14px;
  }
  .article-ad-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }
  .article-ad-title {
    font-size: 0.95rem;
    font-weight: 800;
    margin-bottom: 4px;
  }
  .article-ad-desc {
    font-size: 0.8rem;
    color: var(--text-mid);
    line-height: 1.6;
  }
  .article-ad-badge {
    display: inline-block;
    margin-top: 6px;
    padding: 2px 10px;
    background: #e8f5e9;
    color: #2e7d32;
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 10px;
  }
  .article-ad-cta {
    display: block;
    text-align: center;
    padding: 12px 20px;
    background: linear-gradient(135deg, #c8a84b, #b8960a);
    color: white;
    border-radius: 8px;
    font-weight: 800;
    font-size: 0.9rem;
    box-shadow: 0 3px 8px rgba(200,168,75,0.3);
  }
  .article-ad-card:hover .article-ad-cta {
    box-shadow: 0 4px 14px rgba(200,168,75,0.4);
  }
</style>
